LLM_PROVIDER=ollama

# Ollama (default, fully local — install from https://ollama.com, then: ollama pull llama3.1:8b)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Groq (optional alt, free tier — get key at https://console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
